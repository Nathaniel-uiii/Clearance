# Copy this file to ".env" and fill in values. Never commit ".env".

# ---------------------------------------------------------------------------
# Database — REQUIRED for Supabase
# ---------------------------------------------------------------------------
# Default (local dev, NOT Supabase): SQLite file next to the API
# DATABASE_URL=sqlite:///./prime_local.db

# Supabase Postgres (use your password and host from Supabase → Settings → Database)
# SQLAlchemy 2 + psycopg3 URI format (note "+psycopg"):
# DATABASE_URL=postgresql+psycopg://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#
# Session pooler (port 6543) or direct (port 5432) both work. SSL is added in code if omitted.
# See SUPABASE_SETUP.md for step-by-step instructions.

DATABASE_URL=sqlite:///./prime_local.db

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_ALG=HS256
JWT_EXPIRES_MINUTES=10080

# ---------------------------------------------------------------------------
# CORS — add the exact origin where Next.js runs (scheme + host + port)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
